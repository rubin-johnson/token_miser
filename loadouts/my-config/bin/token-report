#!/bin/bash
#
# Token Usage Report Generator
# Usage: token-report [summary|daily|weekly|by-repo|by-category|recent]
#

set -euo pipefail

DB="$HOME/.claude/token-usage.db"

if [ ! -f "$DB" ]; then
    echo "No token usage data found. Database will be created after first session."
    exit 1
fi

REPORT_TYPE="${1:-summary}"

case "$REPORT_TYPE" in
    summary)
        echo "=== Token Usage Summary ==="
        echo
        sqlite3 -column -header "$DB" <<'EOF'
SELECT
    COUNT(*) as total_sessions,
    SUM(tokens_total) as total_tokens,
    AVG(tokens_total) as avg_tokens_per_session,
    MIN(date) as first_session,
    MAX(date) as last_session
FROM sessions
WHERE tokens_total > 0;
EOF
        ;;

    daily)
        echo "=== Daily Token Usage (Last 30 Days) ==="
        echo
        sqlite3 -column -header "$DB" <<'EOF'
SELECT
    date,
    COUNT(*) as sessions,
    SUM(tokens_total) as total_tokens,
    AVG(tokens_total) as avg_tokens
FROM sessions
WHERE date >= date('now', '-30 days')
AND tokens_total > 0
GROUP BY date
ORDER BY date DESC;
EOF
        ;;

    weekly)
        echo "=== Weekly Token Usage ==="
        echo
        sqlite3 -column -header "$DB" <<'EOF'
SELECT
    strftime('%Y-W%W', date) as week,
    COUNT(*) as sessions,
    SUM(tokens_total) as total_tokens,
    AVG(tokens_total) as avg_tokens
FROM sessions
WHERE tokens_total > 0
GROUP BY week
ORDER BY week DESC
LIMIT 12;
EOF
        ;;

    by-repo)
        echo "=== Token Usage by Repository ==="
        echo
        sqlite3 -column -header "$DB" <<'EOF'
SELECT
    git_repo,
    COUNT(*) as sessions,
    SUM(tokens_total) as total_tokens,
    AVG(tokens_total) as avg_tokens
FROM sessions
WHERE git_repo != ''
AND tokens_total > 0
GROUP BY git_repo
ORDER BY total_tokens DESC
LIMIT 20;
EOF
        ;;

    by-category)
        echo "=== Token Usage by Category ==="
        echo
        sqlite3 -column -header "$DB" <<'EOF'
SELECT
    category,
    COUNT(*) as sessions,
    SUM(tokens_total) as total_tokens,
    AVG(tokens_total) as avg_tokens,
    ROUND(SUM(tokens_total) * 100.0 / (SELECT SUM(tokens_total) FROM sessions WHERE tokens_total > 0), 1) as percentage
FROM sessions
WHERE tokens_total > 0
GROUP BY category
ORDER BY total_tokens DESC;
EOF
        ;;

    by-model)
        echo "=== Token Usage by Model ==="
        echo
        sqlite3 -column -header "$DB" <<'EOF'
SELECT
    COALESCE(NULLIF(model, ''), 'unknown') as model,
    COUNT(*) as sessions,
    SUM(tokens_total) as total_tokens,
    AVG(tokens_total) as avg_tokens,
    ROUND(SUM(tokens_total) * 100.0 / (SELECT SUM(tokens_total) FROM sessions WHERE tokens_total > 0), 1) as percentage
FROM sessions
WHERE tokens_total > 0
GROUP BY model
ORDER BY total_tokens DESC;
EOF
        ;;

    recent)
        echo "=== Recent Sessions (Last 20) ==="
        echo
        sqlite3 -column -header "$DB" <<'EOF'
SELECT
    timestamp,
    COALESCE(NULLIF(model, ''), 'unknown') as model,
    category,
    git_repo,
    tokens_total
FROM sessions
WHERE tokens_total > 0
ORDER BY timestamp DESC
LIMIT 20;
EOF
        ;;

    trends)
        echo "=== Token Usage Trends (7-day rolling average) ==="
        echo
        sqlite3 -column -header "$DB" <<'EOF'
WITH daily_totals AS (
    SELECT
        date,
        SUM(tokens_total) as daily_tokens
    FROM sessions
    WHERE tokens_total > 0
    GROUP BY date
)
SELECT
    date,
    daily_tokens,
    ROUND(AVG(daily_tokens) OVER (
        ORDER BY date
        ROWS BETWEEN 6 PRECEDING AND CURRENT ROW
    ), 0) as rolling_7day_avg
FROM daily_totals
ORDER BY date DESC
LIMIT 30;
EOF
        ;;

    credits)
        ACCOUNT="${2:-work}"
        echo "=== API Credits: $ACCOUNT ==="
        echo

        # Check if credit_events table exists and has data
        HAS_EVENTS=$(sqlite3 "$DB" "SELECT COUNT(*) FROM credit_events WHERE account = '$ACCOUNT';" 2>/dev/null || echo "0")
        if [ "$HAS_EVENTS" -eq 0 ]; then
            echo "No credit events recorded for '$ACCOUNT'."
            echo "Run: credits-add <amount> [$ACCOUNT]"
            exit 0
        fi

        echo "--- Credit History ---"
        sqlite3 -column -header "$DB" <<EOF
SELECT date, printf('\$%.2f', amount_usd) as amount, notes
FROM credit_events WHERE account = '$ACCOUNT'
ORDER BY date DESC LIMIT 10;
EOF
        echo

        # Balance summary
        echo "--- Balance ---"
        sqlite3 -column -header "$DB" <<EOF
SELECT
    printf('\$%.2f', SUM(ce.amount_usd)) as total_loaded,
    printf('\$%.2f', COALESCE((SELECT SUM(cost_usd) FROM sessions WHERE account = '$ACCOUNT' AND cost_usd IS NOT NULL), 0)) as total_spent,
    printf('\$%.2f', SUM(ce.amount_usd) - COALESCE((SELECT SUM(cost_usd) FROM sessions WHERE account = '$ACCOUNT' AND cost_usd IS NOT NULL), 0)) as balance_remaining
FROM credit_events ce WHERE ce.account = '$ACCOUNT';
EOF
        echo

        echo "--- Forecast ---"
        # Two-step aggregation: sum cost per day first, then average those daily totals.
        # This treats days with zero spend as absent (excluded), not zero — giving a
        # "when you work, how much do you spend?" rate rather than a calendar-day rate.
        DAILY_AVG=$(sqlite3 "$DB" <<EOF
SELECT COALESCE(AVG(daily_cost), 0)
FROM (
    SELECT date, SUM(cost_usd) as daily_cost
    FROM sessions
    WHERE account = '$ACCOUNT'
      AND cost_usd IS NOT NULL
      AND date >= date('now', '-7 days')
    GROUP BY date
);
EOF
        )

        BALANCE=$(sqlite3 "$DB" <<EOF
SELECT COALESCE(SUM(ce.amount_usd), 0) - COALESCE(
    (SELECT SUM(cost_usd) FROM sessions WHERE account = '$ACCOUNT' AND cost_usd IS NOT NULL), 0)
FROM credit_events ce WHERE ce.account = '$ACCOUNT';
EOF
        )

        if [[ -z "$DAILY_AVG" ]] || (( $(echo "$DAILY_AVG == 0" | bc -l) )); then
            echo "Burn rate: no recent sessions (7d avg)"
        else
            DAYS_REMAINING=$(echo "scale=1; $BALANCE / $DAILY_AVG" | bc -l)
            DAYS_INT=$(echo "$DAYS_REMAINING" | cut -d. -f1)
            RATE_FMT=$(printf '$%.2f' "$DAILY_AVG")
            echo "Burn rate: ${RATE_FMT}/day (7d avg, active days only) — ~${DAYS_REMAINING} days remaining"
            if (( DAYS_INT < 7 )) && (( DAYS_INT >= 0 )); then
                echo "WARNING: less than a week of credits at current pace"
            fi
        fi
        ;;

    *)
        echo "Usage: token-report [summary|daily|weekly|by-repo|by-category|by-model|recent|trends|credits]"
        echo
        echo "Available reports:"
        echo "  summary      - Overall statistics"
        echo "  daily        - Daily breakdown (last 30 days)"
        echo "  weekly       - Weekly breakdown (last 12 weeks)"
        echo "  by-repo      - Token usage per repository"
        echo "  by-category  - Token usage per category"
        echo "  by-model     - Token usage per model"
        echo "  recent       - Last 20 sessions (includes model)"
        echo "  trends       - 7-day rolling average"
        echo "  credits      - API credit balance and burn rate [account]"
        exit 1
        ;;
esac
