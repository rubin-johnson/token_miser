[Turn 16] Tool: write_file({'path': 'token_miser/models/anomaly_alert.py', 'content': '"""AnomalyAlert model for Token Miser."""\nfrom datetime import datetime\nfrom typing import Optional\n\n\nclass AnomalyAlert:\n    """Represents an alert for anomalous token usage."""\n\n    _id_counter = 1\n    _instances = {}\n\n    def __init__(\n        self,\n        project_id=None,\n        team_id=None,\n        baseline_tokens=0,\n        current_tokens=0,\n        spike_magnitude=1.0,\n        spike_percentage=0.0,\n        timestamp=None,\n        project_name=None,\n    ):\n        """Initialize anomaly alert.\n        \n        Args:\n            project_id: The project ID\n            team_id: The team ID\n            baseline_tokens: Baseline token usage\n            current_tokens: Current token usage\n            spike_magnitude: Magnitude of spike (current / baseline)\n            spike_percentage: Percentage increase from baseline\n            timestamp: Datetime of the alert\n            project_name: Name of the project\n        """\n        self.id = AnomalyAlert._id_counter\n        AnomalyAlert._id_counter += 1\n        self.project_id = project_id\n        self.team_id = team_id\n        self.baseline_tokens = baseline_tokens\n        self.current_tokens = current_tokens\n        self.spike_magnitude = spike_magnitude\n        self.spike_percentage = spike_percentage\n        self.timestamp = timestamp or datetime.utcnow()\n        self.project_name = project_name\n        AnomalyAlert._instances[self.id] = self\n\n    @classmethod\n    def objects(cls):\n        """Return the objects manager."""\n        return AnomalyAlertManager()\n\n    def __repr__(self):\n        return f"<AnomalyAlert {self.id}: {self.spike_magnitude:.1f}x spike in {self.project_name}>"\n\n\nclass AnomalyAlertManager:\n    """Manager for AnomalyAlert objects (mimics Django ORM)."""\n\n    def create(\n        self,\n        project_id=None,\n        team_id=None,\n        baseline_tokens=0,\n        current_tokens=0,\n        spike_magnitude=1.0,\n        spike_percentage=0.0,\n        timestamp=None,\n        project_name=None,\n    ):\n        """Create a new anomaly alert.\n        \n        Args:\n            project_id: The project ID\n            team_id: The team ID\n            baseline_tokens: Baseline token usage\n            current_tokens: Current token usage\n            spike_magnitude: Magnitude of spike (current / baseline)\n            spike_percentage: Percentage increase from baseline\n            timestamp: Datetime of the alert\n            project_name: Name of the project\n            \n        Returns:\n            The created AnomalyAlert instance\n        """\n        return AnomalyAlert(\n            project_id=project_id,\n            team_id=team_id,\n            baseline_tokens=baseline_tokens,\n            current_tokens=current_tokens,\n            spike_magnitude=spike_magnitude,\n            spike_percentage=spike_percentage,\n            timestamp=timestamp,\n            project_name=project_name,\n        )\n\n    def get(self, id):\n        """Get anomaly alert by ID."""\n        return AnomalyAlert._instances[id]\n\n    def all(self):\n        """Get all anomaly alerts."""\n        return list(AnomalyAlert._instances.values())\n\n    def filter(self, **kwargs):\n        """Filter anomaly alerts by attributes."""\n        results = []\n        for alert in AnomalyAlert._instances.values():\n            match = True\n            for key, value in kwargs.items():\n                if not hasattr(alert, key) or getattr(alert, key) != value:\n                    match = False\n                    break\n            if match:\n                results.append(alert)\n        return results\n\n    def exists(self):\n        """Check if any records exist (for existence checks)."""\n        return len(AnomalyAlert._instances) > 0\n\n\n# Module-level objects manager\nclass Objects:\n    """Module-level manager for anomaly alerts."""\n\n    @staticmethod\n    def create(\n        project_id=None,\n        team_id=None,\n        baseline_tokens=0,\n        current_tokens=0,\n        spike_magnitude=1.0,\n        spike_percentage=0.0,\n        timestamp=None,\n        project_name=None,\n    ):\n        """Create a new anomaly alert."""\n        return AnomalyAlert(\n            project_id=project_id,\n            team_id=team_id,\n            baseline_tokens=baseline_tokens,\n            current_tokens=current_tokens,\n            spike_magnitude=spike_magnitude,\n            spike_percentage=spike_percentage,\n            timestamp=timestamp,\n            project_name=project_name,\n        )\n\n    @staticmethod\n    def get(id):\n        """Get anomaly alert by ID."""\n        return AnomalyAlert._instances[id]\n\n    @staticmethod\n    def all():\n        """Get all anomaly alerts."""\n        return list(AnomalyAlert._instances.values())\n\n    @staticmethod\n    def filter(**kwargs):\n        """Filter anomaly alerts by attributes."""\n        results = []\n        for alert in AnomalyAlert._instances.values():\n            match = True\n            for key, value in kwargs.items():\n                if not hasattr(alert, key) or getattr(alert, key) != value:\n                    match = False\n                    break\n            if match:\n                results.append(alert)\n        return results\n\n\n# Attach objects manager to class\nAnomalyAlert.objects = Objects\n'})
