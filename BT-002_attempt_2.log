[Turn 19] Tool: write_file({'path': 'token_miser/services/anomaly_detector.py', 'content': '"""Anomaly detection service for token usage."""\nfrom datetime import datetime, timedelta\nfrom typing import List, Dict, Optional\nfrom token_miser.models import TokenUsage, Project, AnomalyAlert\n\n\nclass AnomalyDetector:\n    """Detects anomalies in token usage patterns."""\n    \n    def __init__(self, team_id: int, sensitivity: float = 1.5):\n        """Initialize the anomaly detector.\n        \n        Args:\n            team_id: The team ID to detect anomalies for\n            sensitivity: Threshold multiplier for spike detection (e.g., 1.5 = 150%)\n        """\n        self.team_id = team_id\n        self.sensitivity = sensitivity\n    \n    def detect_anomalies(self, lookback_days: int = 30) -> List[Dict]:\n        """Detect anomalies in token usage.\n        \n        Args:\n            lookback_days: Number of days to use for baseline calculation\n            \n        Returns:\n            List of anomaly dictionaries with details\n        """\n        anomalies = []\n        \n        # Get all projects for this team\n        projects = Project.objects.filter(team_id=self.team_id)\n        \n        now = datetime.utcnow()\n        baseline_start = now - timedelta(days=lookback_days)\n        \n        for project in projects:\n            # Calculate baseline for this project\n            baseline = self._calculate_baseline(project.id, lookback_days)\n            \n            if baseline == 0:\n                # Can\'t detect anomalies without baseline\n                continue\n            \n            # Get most recent usage for this project\n            recent_usage = self._get_recent_usage(project.id, hours=24)\n            \n            if not recent_usage:\n                continue\n            \n            # Calculate current usage (sum of recent usage)\n            current_tokens = sum(u.total_tokens for u in recent_usage)\n            \n            # Check if it\'s an anomaly\n            spike_magnitude = current_tokens / baseline if baseline > 0 else 1.0\n            \n            if spike_magnitude >= self.sensitivity:\n                # This is an anomaly!\n                spike_percentage = ((current_tokens - baseline) / baseline) * 100\n                \n                # Get the most recent timestamp\n                recent_timestamp = max(u.timestamp for u in recent_usage)\n                \n                anomaly = {\n                    "project_id": project.id,\n                    "project_name": project.name,\n                    "baseline_tokens": baseline,\n                    "current_tokens": current_tokens,\n                    "spike_magnitude": spike_magnitude,\n                    "spike_percentage": spike_percentage,\n                    "timestamp": recent_timestamp,\n                }\n                \n                anomalies.append(anomaly)\n                \n                # Persist the anomaly alert to database\n                AnomalyAlert.objects.create(\n                    project_id=project.id,\n                    team_id=self.team_id,\n                    baseline_tokens=baseline,\n                    current_tokens=current_tokens,\n                    spike_magnitude=spike_magnitude,\n                    spike_percentage=spike_percentage,\n                    timestamp=recent_timestamp,\n                    project_name=project.name,\n                )\n        \n        return anomalies\n    \n    def _calculate_baseline(self, project_id: int, lookback_days: int = 30) -> float:\n        """Calculate the baseline token usage for a project.\n        \n        Args:\n            project_id: The project ID\n            lookback_days: Number of days to use for baseline\n            \n        Returns:\n            Average daily token usage\n        """\n        now = datetime.utcnow()\n        baseline_start = now - timedelta(days=lookback_days)\n        \n        # Get all usages for this project in the lookback period\n        project = Project.objects.get(project_id)\n        usages = TokenUsage.objects.filter(project=project)\n        \n        # Filter to lookback period\n        usages_in_period = [\n            u for u in usages \n            if baseline_start <= u.timestamp <= now\n        ]\n        \n        if not usages_in_period:\n            return 0.0\n        \n        # Calculate total tokens\n        total_tokens = sum(u.total_tokens for u in usages_in_period)\n        \n        # Calculate average per day\n        average_per_day = total_tokens / lookback_days\n        \n        return average_per_day\n    \n    def _get_recent_usage(self, project_id: int, hours: int = 24) -> List:\n        """Get recent token usage for a project.\n        \n        Args:\n            project_id: The project ID\n            hours: Number of hours to look back\n            \n        Returns:\n            List of TokenUsage objects\n        """\n        now = datetime.utcnow()\n        lookback_time = now - timedelta(hours=hours)\n        \n        # Get the project\n        project = Project.objects.get(project_id)\n        \n        # Get all usages for this project\n        usages = TokenUsage.objects.filter(project=project)\n        \n        # Filter to recent period\n        recent = [\n            u for u in usages \n            if lookback_time <= u.timestamp <= now\n        ]\n        \n        return recent\n'})
