 0.0\n            week_tokens = 0\n            \n            for usage in usages:\n                if period_start <= usage.timestamp < period_end:\n                    week_cost += usage.cost\n                    week_tokens += usage.total_tokens\n            \n            weeks_data.append({\n                "week_start": period_start,\n                "week_end": period_end,\n                "cost": week_cost,\n                "tokens": week_tokens,\n            })\n        \n        # Reverse to get newest first\n        weeks_data.reverse()\n        \n        # Build result list with week_cost key\n        trends = []\n        for i, data in enumerate(weeks_data):\n            trend = {\n                "week_cost": data["cost"],\n                "total_tokens": data["tokens"],\n                "week_start": data["week_start"],\n                "week_end": data["week_end"],\n            }\n            \n            # Calculate percentage change comparing current week to previous (older) week\n            # In the reversed list, the previous older week is at i+1\n            if i + 1 < len(weeks_data) and weeks_data[i + 1]["cost"] > 0:\n                # weeks_data[i+1] is older than weeks_data[i]\n                previous_cost = weeks_data[i + 1]["cost"]\n                percentage_change = ((data["cost"] - previous_cost) / previous_cost) * 100\n                trend["percentage_change"] = percentage_change\n            \n            trends.append(trend)\n        \n        return trends\n\n    def get_monthly_trends(self, project_id, num_months=2):\n        """Get month-over-month cost trends.\n        \n        Args:\n            project_id: The project ID to analyze\n            num_months: Number of months to return\n            \n        Returns:\n            List of dicts with monthly trend data including:\n            - month_cost: Total cost for the month\n            - percentage_change: MoM percentage change\n            - total_tokens: Total tokens for the month\n            \n        Returns trends ordered from most recent to oldest.\n        """\n        # Get the project\n        project = Project.objects.get(project_id)\n        \n        # Get all usages for this project, sorted by timestamp\n        usages = sorted(\n            TokenUsage.objects.filter(project=project),\n            key=lambda u: u.timestamp\n        )\n        \n        if not usages:\n            return []\n        \n        # Group into 30-day periods, starting from the oldest data\n        # and going forward in time\n        oldest = usages[0].timestamp\n        \n        months_data = []\n        for month_num in range(num_months):\n            # Calculate the period for this month (30 days)\n            period_start = oldest + timedelta(days=month_num * 30)\n            period_end = period_start + timedelta(days=30)\n            \n            # Find all usages in this period\n            month_cost = 0.0\n            month_tokens = 0\n            \n            for usage in usages:\n                if period_start <= usage.timestamp < period_end:\n                    month_cost += usage.cost\n                    month_tokens += usage.total_tokens\n            \n            months_data.append({\n                "month_start": period_start,\n                "month_end": period_end,\n                "cost": month_cost,\n                "tokens": month_tokens,\n            })\n        \n        # Reverse to get newest first\n        months_data.reverse()\n        \n        # Build result list with month_cost key\n        trends = []\n        for i, data in enumerate(months_data):\n            trend = {\n                "month_cost": data["cost"],\n                "total_tokens": data["tokens"],\n                "month_start": data["month_start"],\n            }\n            \n            # Calculate percentage change comparing current month to previous (older) month\n            # In the reversed list, the previous older month is at i+1\n            if i + 1 < len(months_data) and months_data[i + 1]["cost"] > 0:\n                # months_data[i+1] is older than months_data[i]\n                previous_cost = months_data[i + 1]["cost"]\n                percentage_change = ((data["cost"] - previous_cost) / previous_cost) * 100\n                trend["percentage_change"] = percentage_change\n            \n            trends.append(trend)\n        \n        return trends\n\n    def get_trends_for_date_range(self, project_id, start_date, end_date, period="week"):\n        """Get trends for a custom date range.\n        \n        Args:\n            project_id: The project ID to analyze\n            start_date: Start date for the range\n            end_date: End date for the range\n            period: Period type ("week" or "month")\n            \n        Returns:\n            List of dicts with trend data for the specified period\n        """\n        # Get the project\n        project = Project.objects.get(project_id)\n        \n        # Get all usages for this project\n        usages = TokenUsage.objects.filter(project=project)\n        \n        # Filter by date range\n        filtered_usages = []\n        for usage in usages:\n            if start_date <= usage.timestamp <= end_date:\n                filtered_usages.append(usage)\n        \n        if period == "week":\n            # Group by week (7-day periods from start_date)\n            weeks_data = {}\n            \n            for usage in filtered_usages:\n                # Calculate which 7-day period this usage falls into\n                days_since_start = (usage.timestamp - start_date).days\n                period_num = days_since_start // 7\n                \n                period_start = start_date + timedelta(days=period_num * 7)\n                period_end = period_start + timedelta(days=6, hours=23, minutes=59, seconds=59)\n                \n                week_key = period_start.strftime("%Y-%m-%d")\n                \n                if week_key not in weeks_data:\n                    weeks_data[week_key] = {\n                        "cost": 0.0,\n                        "tokens": 0,\n                        "week_start": period_start,\n                        "week_end": period_end,\n                    }\n                \n                weeks_data[week_key]["cost"] += usage.cost\n                weeks_data[week_key]["tokens"] += usage.total_tokens\n            \n            # Sort by date\n            sorted_periods = sorted(weeks_data.items(), key=lambda x: x[1]["week_start"])\n            \n            trends = []\n            for week_key, data in sorted_periods:\n                trends.append({\n                    "week_start": data["week_start"],\n                    "week_end": data["week_end"],\n                    "cost": data["cost"],\n                    "total_tokens": data["tokens"],\n                })\n            \n            return trends\n        \n        elif period == "month":\n            # Group by month\n            months_data = {}\n            \n            for usage in filtered_usages:\n                month_start = usage.timestamp.replace(day=1, hour=0, minute=0, second=0, microsecond=0)\n                month_key = month_start.strftime("%Y-%m")\n                \n                if month_key not in months_data:\n                    months_data[month_key] = {\n                        "cost": 0.0,\n                        "tokens": 0,\n                        "month_start": month_start,\n                    }\n                \n                months_data[month_key]["cost"] += usage.cost\n                months_data[month_key]["tokens"] += usage.total_tokens\n            \n            # Sort by date\n            sorted_periods = sorted(months_data.items(), key=lambda x: x[1]["month_start"])\n            \n            trends = []\n            for month_key, data in sorted_periods:\n                trends.append({\n                    "month_start": data["month_start"],\n                    "cost": data["cost"],\n                    "total_tokens": data["tokens"],\n                })\n            \n            return trends\n        \n        return []\n\n    def get_trends_by_project(self):\n        """Get trends for all projects in the team.\n        \n        Returns:\n            List of dicts with trend data for each project\n        """\n        # Get all projects for this team\n        projects = Project.objects.filter(team_id=self.team_id)\n        \n        trends_by_project = []\n        for project in projects:\n            # Get weekly trends for each project\n            weekly_trends = self.get_weekly_trends(project_id=project.id, num_weeks=1)\n            \n            trends_by_project.append({\n                "project_id": project.id,\n                "project_name": project.name,\n                "trends": weekly_trends,\n            })\n        \n        return trends_by_project\n'})
