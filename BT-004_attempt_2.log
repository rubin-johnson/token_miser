[Turn 24] Tool: write_file({'path': 'token_miser/services/trending.py', 'content': '"""Trending analysis services for Token Miser."""\nfrom datetime import datetime, timedelta\nfrom typing import List, Dict, Optional\nfrom collections import defaultdict\nfrom token_miser.models import TokenUsage, Project\n\n\nclass TrendingAnalyzer:\n    """Analyzes historical trends in token costs."""\n\n    def __init__(self, team_id):\n        """Initialize the trending analyzer.\n        \n        Args:\n            team_id: The team ID to analyze trends for\n        """\n        self.team_id = team_id\n\n    def get_weekly_trends(self, project_id, num_weeks=2):\n        """Get week-over-week cost trends.\n        \n        Args:\n            project_id: The project ID to analyze\n            num_weeks: Number of weeks to return\n            \n        Returns:\n            List of dicts with weekly trend data including:\n            - week_cost: Total cost for the week\n            - percentage_change: WoW percentage change\n            - total_tokens: Total tokens for the week\n        """\n        # Get the project\n        project = Project.objects.get(project_id)\n        \n        # Get all usages for this project, sorted by timestamp\n        usages = sorted(\n            TokenUsage.objects.filter(project=project),\n            key=lambda u: u.timestamp\n        )\n        \n        if not usages:\n            return []\n        \n        # Group into 7-day periods from the end (most recent data)\n        # We\'ll work backwards from now to create rolling 7-day windows\n        now = datetime.utcnow()\n        \n        weeks_data = []\n        for week_num in range(num_weeks):\n            # Calculate the period for this week\n            # Week 0 is the most recent, Week 1 is before that, etc.\n            period_end = now - timedelta(days=week_num * 7)\n            period_start = period_end - timedelta(days=7)\n            \n            # Find all usages in this period\n            week_cost = 0.0\n            week_tokens = 0\n            \n            for usage in usages:\n                if period_start < usage.timestamp <= period_end:\n                    week_cost += usage.cost\n                    week_tokens += usage.total_tokens\n            \n            weeks_data.append({\n                "week_start": period_start,\n                "week_end": period_end,\n                "cost": week_cost,\n                "tokens": week_tokens,\n            })\n        \n        # Reverse to get oldest first\n        weeks_data.reverse()\n        \n        # Build result list with week_cost key\n        trends = []\n        for i, data in enumerate(weeks_data):\n            trend = {\n                "week_cost": data["cost"],\n                "total_tokens": data["tokens"],\n                "week_start": data["week_start"],\n                "week_end": data["week_end"],\n            }\n            \n            # Calculate percentage change if we have a previous week\n            if i > 0 and weeks_data[i - 1]["cost"] > 0:\n                previous_cost = weeks_data[i - 1]["cost"]\n                percentage_change = ((data["cost"] - previous_cost) / previous_cost) * 100\n                trend["percentage_change"] = percentage_change\n            \n            trends.append(trend)\n        \n        return trends\n\n    def get_monthly_trends(self, project_id, num_months=2):\n        """Get month-over-month cost trends.\n        \n        Args:\n            project_id: The project ID to analyze\n            num_months: Number of months to return\n            \n        Returns:\n            List of dicts with monthly trend data including:\n            - month_cost: Total cost for the month\n            - percentage_change: MoM percentage change\n            - total_tokens: Total tokens for the month\n        """\n        # Get the project\n        project = Project.objects.get(project_id)\n        \n        # Get all usages for this p