[Turn 13] Tool: write_file({'path': 'token_miser/services/trending.py', 'content': '"""Trending analysis services for Token Miser."""\nfrom datetime import datetime, timedelta\nfrom typing import List, Dict, Optional\nfrom collections import defaultdict\nfrom token_miser.models import TokenUsage, Project\n\n\nclass TrendingAnalyzer:\n    """Analyzes token cost trends over time."""\n\n    def __init__(self, team_id):\n        """Initialize the trending analyzer.\n        \n        Args:\n            team_id: The team ID to analyze trends for\n        """\n        self.team_id = team_id\n\n    def get_weekly_trends(self, project_id: int, num_weeks: int = 4) -> List[Dict]:\n        """Get week-over-week cost trends.\n        \n        Args:\n            project_id: The project ID to get trends for\n            num_weeks: Number of weeks to retrieve (most recent first)\n            \n        Returns:\n            List of dicts with weekly trend data, ordered with current week first\n        """\n        project = Project.objects.get(project_id)\n        usages = TokenUsage.objects.filter(project=project)\n        \n        if not usages:\n            return []\n        \n        # Group usages by week\n        weeks_data = defaultdict(lambda: {"cost": 0, "tokens": 0, "count": 0})\n        \n        now = datetime.utcnow()\n        \n        for usage in usages:\n            # Calculate which week this usage belongs to\n            days_ago = (now - usage.timestamp).days\n            if days_ago < 0:\n                continue\n            \n            # Week number (0 = current week, 1 = last week, etc.)\n            week_num = days_ago // 7\n            \n            if week_num >= num_weeks:\n                continue\n            \n            weeks_data[week_num]["cost"] += usage.cost\n            weeks_data[week_num]["tokens"] += usage.total_tokens\n            weeks_data[week_num]["count"] += 1\n        \n        # Build result list, sorted by week (current first)\n        trends = []\n        for week_num in sorted(weeks_data.keys()):\n            data = weeks_data[week_num]\n            if week_num == 0:\n                # Current week\n                week_start = now - timedelta(days=now.weekday())\n                week_end = week_start + timedelta(days=6)\n            else:\n                # Previous weeks\n                week_start = now - timedelta(days=now.weekday() + 7 * week_num)\n                week_end = week_start + timedelta(days=6)\n            \n            trend_entry = {\n                "week_number": week_num,\n                "week_start": week_start,\n                "week_end": week_end,\n                "week_cost": data["cost"],\n                "total_tokens": data["tokens"],\n                "usage_count": data["count"],\n            }\n            \n            # Calculate percentage change from previous week\n            if week_num > 0 and (week_num - 1) in weeks_data:\n                prev_cost = weeks_data[week_num - 1]["cost"]\n                if prev_cost > 0:\n                    pct_change = ((data["cost"] - prev_cost) / prev_cost) * 100\n                    trend_entry["percentage_change"] = pct_change\n                else:\n                    trend_entry["percentage_change"] = 0.0\n            else:\n                trend_entry["percentage_change"] = 0.0\n            \n            trends.append(trend_entry)\n        \n        # Return with current week first\n        trends.reverse()\n        \n        # Calculate percentage change for first week (current) vs previous\n        if len(trends) >= 2:\n            current_cost = trends[0]["week_cost"]\n            previous_cost = trends[1]["week_cost"]\n            if previous_cost > 0:\n                pct_change = ((current_cost - previous_cost) / previous_cost) * 100\n                trends[0]["percentage_change"] = pct_change\n        \n        return trends\n\n    def get_monthly_trends(self, project_id: int, num_months: int = 12) -> List[Dict]:\n        """Get month-over-month cost trends.\n        \n        Args:\n            project_id: The project ID to get trends for\n            num_months: Number of months to retrieve (most recent first)\n            \n        Returns:\n            List of dicts with monthly trend data, ordered with current month first\n        """\n        project = Project.objects.get(project_id)\n        usages = TokenUsage.objects.filter(project=project)\n        \n        if not usages:\n            return []\n        \n        # Group usages by month\n        months_data = defaultdict(lambda: {"cost": 0, "tokens": 0, "count": 0})\n        \n        now = datetime.utcnow()\n        \n        for usage in usages:\n            # Calculate which month this usage belongs to\n            months_ago = (now.year - usage.timestamp.year) * 12 + (now.month - usage.timestamp.month)\n            \n            if months_ago < 0 or months_ago >= num_months:\n                continue\n            \n            months_data[months_ago]["cost"] += usage.cost\n            months_data[months_ago]["tokens"] += usage.total_tokens\n            months_data[months_ago]["count"] += 1\n        \n        # Build result list\n        trends = []\n        for month_num in sorted(months_data.keys()):\n            data = months_data[month_num]\n            \n            # Calculate month start and end dates\n            month_start = now - timedelta(days=now.day - 1)\n            month_start = month_start.replace(day=1)\n            for _ in range(month_num):\n                if month_start.month == 1:\n                    month_start = month_start.replace(year=month_start.year - 1, month=12)\n                else:\n                    month_start = month_start.replace(month=month_start.month - 1)\n            \n            # Calculate month end\n            if month_start.month == 12:\n                month_end = month_start.replace(year=month_start.year + 1, month=1, day=1) - timedelta(days=1)\n            else:\n                month_end = month_start.replace(month=month_start.month + 1, day=1) - timedelta(days=1)\n            \n            trend_entry = {\n                "month_number": month_num,\n                "month_start": month_start,\n                "month_end": month_end,\n                "month_cost": data["cost"],\n                "total_tokens": data["tokens"],\n                "usage_count": data["count"],\n            }\n            \n            # Calculate percentage change from previous month\n            if month_num > 0 and (month_num - 1) in months_data:\n                prev_cost = months_data[month_num - 1]["cost"]\n                if prev_cost > 0:\n                    pct_change = ((data["cost"] - prev_cost) / prev_cost) * 100\n                    trend_entry["percentage_change"] = pct_change\n                else:\n                    trend_entry["percentage_change"] = 0.0\n            else:\n                trend_entry["percentage_change"] = 0.0\n            \n            trends.append(trend_entry)\n        \n        # Return with current month first\n        trends.reverse()\n        \n        # Calculate percentage change for first month (current) vs previous\n        if len(trends) >= 2:\n            current_cost = trends[0]["month_cost"]\n            previous_cost = trends[1]["month_cost"]\n            if previous_cost > 0:\n                pct_change = ((current_cost - previous_cost) / previous_cost) * 100\n                trends[0]["percentage_change"] = pct_change\n        \n        return trends\n\n    def get_trends_for_date_range(\n        self,\n        project_id: int,\n        start_date: datetime,\n        end_date: datetime,\n        period: str = "week"\n    ) -> List[Dict]:\n        """Get trends for a custom date range.\n        \n        Args:\n            project_id: The project ID to get trends for\n            start_date: Start of date range\n            end_date: End of date range\n            period: Period to group by ("week" or "month")\n            \n        Returns:\n            List of dicts with trend data for each period\n        """\n        project = Project.objects.get(project_id)\n        usages = TokenUsage.objects.filter(project=project)\n        \n        if not usages:\n            return []\n        \n        # Filter usages to date range\n        filtered_usages = [\n            u for u in usages\n            if start_date <= u.timestamp <= end_date\n        ]\n        \n        if not filtered_usages:\n            return []\n        \n        if period == "week":\n            # Group by week\n            weeks_data = defaultdict(lambda: {"cost": 0, "tokens": 0})\n            \n            for usage in filtered_usages:\n                # Calculate week start (Monday)\n                week_start = usage.timestamp - timedelta(days=usage.timestamp.weekday())\n                week_start = week_start.replace(hour=0, minute=0, second=0, microsecond=0)\n                week_key = week_start.isoformat()\n                \n                weeks_data[week_key]["cost"] += usage.cost\n                weeks_data[week_key]["tokens"] += usage.total_tokens\n                weeks_data[week_key]["start"] = week_start\n            \n            trends = []\n            for week_key in sorted(weeks_data.keys()):\n                data = weeks_data[week_key]\n                week_start = data["start"]\n                week_end = week_start + timedelta(days=6)\n                \n                trends.append({\n                    "week_start": week_start,\n                    "week_end": week_end,\n                    "cost": data["cost"],\n                    "total_tokens": data["tokens"],\n                })\n            \n            return trends\n        \n        elif period == "month":\n            # Group by month\n            months_data = defaultdict(lambda: {"cost": 0, "tokens": 0})\n            \n            for usage in filtered_usages:\n                # Calculate month start\n                month_start = usage.timestamp.replace(day=1, hour=0, minute=0, second=0, microsecond=0)\n                month_key = month_start.isoformat()\n                \n                months_data[month_key]["cost"] += usage.cost\n                months_data[month_key]["tokens"] += usage.total_tokens\n                months_data[month_key]["start"] = month_start\n            \n            trends = []\n            for month_key in sorted(months_data.keys()):\n                data = months_data[month_key]\n                month_start = data["start"]\n                \n                # Calculate month end\n                if month_start.month == 12:\n                    month_end = month_start.replace(year=month_start.year + 1, month=1, day=1) - timedelta(days=1)\n                else:\n                    month_end = month_start.replace(month=month_start.month + 1, day=1) - timedelta(days=1)\n                \n                month_end = month_end.replace(hour=23, minute=59, second=59, microsecond=999999)\n                \n                trends.append({\n                    "month_start": month_start,\n                    "month_end": month_end,\n                    "cost": data["cost"],\n                    "total_tokens": data["tokens"],\n                })\n            \n            return trends\n        \n        return []\n\n    def get_trends_by_project(self) -> List[Dict]:\n        """Get trends for all projects in the team.\n        \n        Returns:\n            List of dicts with trend data per project\n        """\n        projects = Project.objects.filter(team_id=self.team_id)\n        \n        trends_by_project = []\n        for project in projects:\n            usages = TokenUsage.objects.filter(project=project)\n            \n            if not usages:\n                continue\n            \n            # Calculate total cost for current week\n            now = datetime.utcnow()\n            week_cost = 0\n        