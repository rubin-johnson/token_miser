data[week_num]["cost"] += usage.cost\n            weeks_data[week_num]["tokens"] += usage.total_tokens\n            weeks_data[week_num]["count"] += 1\n        \n        # Build result list in ascending week order, then reverse to get most recent first\n        trends = []\n        for week_num in sorted(weeks_data.keys()):\n            if len(trends) >= num_weeks:\n                break\n            \n            data = weeks_data[week_num]\n            \n            # Calculate week start and end dates\n            # week 1 = 1-7 days ago, week 2 = 8-14 days ago, etc.\n            week_end = now - timedelta(days=(week_num - 1) * 7)\n            week_start = week_end - timedelta(days=7)\n            \n            trend_entry = {\n                "week_start": week_start,\n                "week_end": week_end,\n                "week_cost": data["cost"],\n                "total_tokens": data["tokens"],\n                "usage_count": data["count"],\n                "percentage_change": 0.0,\n            }\n            \n            trends.append(trend_entry)\n        \n        # Reverse so most recent week is first\n        trends.reverse()\n        \n        # Calculate percentage changes comparing to previous week (next in list)\n        if len(trends) >= 2:\n            for i in range(len(trends) - 1):\n                current_cost = trends[i]["week_cost"]\n                previous_cost = trends[i + 1]["week_cost"]\n                if previous_cost > 0:\n                    pct_change = ((current_cost - previous_cost) / previous_cost) * 100\n                    trends[i]["percentage_change"] = pct_change\n        \n        return trends\n\n    def get_monthly_trends(self, project_id: int, num_months: int = 12) -> List[Dict]:\n        """Get month-over-month cost trends.\n        \n        Args:\n            project_id: The project ID to get trends for\n            num_months: Number of months to retrieve (most recent first)\n            \n        Returns:\n            List of dicts with monthly trend data, ordered with current month first\n        """\n        project = Project.objects.get(project_id)\n        usages = TokenUsage.objects.filter(project=project)\n        \n        if not usages:\n            return []\n        \n        # Group usages by calendar month\n        months_data = {}  # key: (year, month), value: {"cost": 0, "tokens": 0, "count": 0}\n        \n        for usage in usages:\n            month_key = (usage.timestamp.year, usage.timestamp.month)\n            \n            if month_key not in months_data:\n                months_data[month_key] = {"cost": 0, "tokens": 0, "count": 0}\n            \n            months_data[month_key]["cost"] += usage.cost\n            months_data[month_key]["tokens"] += usage.total_tokens\n            months_data[month_key]["count"] += 1\n        \n        # Build result list, sorted by month (most recent first)\n        trends = []\n        for month_key in sorted(months_data.keys(), reverse=True):\n            if len(trends) >= num_months:\n                break\n            \n            data = months_data[month_key]\n            year, month = month_key\n            \n            # Calculate month start\n            month_start = datetime(year, month, 1, 0, 0, 0, 0)\n            \n            # Calculate month end\n            if month == 12:\n                month_end = datetime(year + 1, 1, 1, 0, 0, 0, 0) - timedelta(days=1)\n            else:\n                month_end = datetime(year, month + 1, 1, 0, 0, 0, 0) - timedelta(days=1)\n            \n            month_end = month_end.replace(hour=23, minute=59, second=59, microsecond=999999)\n            \n            trend_entry = {\n                "month_start": month_start,\n                "month_end": month_end,\n                "month_cost": data["cost"],\n                "total_tokens": data["tokens"],\n                "usage_count": data["count"],\n                "percentage_change": 0.0,\n            }\n            \n            trends.append(trend_entry)\n        \n        # Calculate percentage changes comparing to previous month (next in list)\n        if len(trends) >= 2:\n            for i in range(len(trends) - 1):\n                current_cost = trends[i]["month_cost"]\n                previous_cost = trends[i + 1]["month_cost"]\n                if previous_cost > 0:\n                    pct_change = ((current_cost - previous_cost) / previous_cost) * 100\n                    trends[i]["percentage_change"] = pct_change\n        \n        return trends\n\n    def get_trends_for_date_range(\n        self,\n        project_id: int,\n        start_date: datetime,\n        end_date: datetime,\n        period: str = "week"\n    ) -> List[Dict]:\n        """Get trends for a custom date range.\n        \n        Args:\n            project_id: The project ID to get trends for\n            start_date: Start of date range\n            end_date: End of date range\n            period: Period to group by ("week" or "month")\n            \n        Returns:\n            List of dicts with trend data for each period\n        """\n        project = Project.objects.get(project_id)\n        usages = TokenUsage.objects.filter(project=project)\n        \n        if not usages:\n            return []\n        \n        # Filter usages to date range\n        filtered_usages = [\n            u for u in usages\n            if start_date <= u.timestamp <= end_date\n        ]\n        \n        if not filtered_usages:\n            return []\n        \n        if period == "week":\n            # Group by calendar week\n            weeks_data = {}\n            \n            for usage in filtered_usages:\n                # Calculate week start (Monday)\n                days_since_monday = usage.timestamp.weekday()\n                week_start = usage.timestamp - timedelta(days=days_since_monday)\n                week_start = week_start.replace(hour=0, minute=0, second=0, microsecond=0)\n                week_key = week_start.date()\n                \n                if week_key not in weeks_data:\n                    weeks_data[week_key] = {"cost": 0, "tokens": 0, "start": week_start}\n                \n                weeks_data[week_key]["cost"] += usage.cost\n                weeks_data[week_key]["tokens"] += usage.total_tokens\n            \n            trends = []\n            for week_key in sorted(weeks_data.keys()):\n                data = weeks_data[week_key]\n                week_start = data["start"]\n                week_end = week_start + timedelta(days=6)\n                \n                trends.append({\n                    "week_start": week_start,\n                    "week_end": week_end,\n                    "cost": data["cost"],\n                    "total_tokens": data["tokens"],\n                })\n            \n            return trends\n        \n        elif period == "month":\n            # Group by month\n            months_data = {}\n            \n            for usage in filtered_usages:\n                # Calculate month start\n                month_start = usage.timestamp.replace(day=1, hour=0, minute=0, second=0, microsecond=0)\n                month_key = (month_start.year, month_start.month)\n                \n                if month_key not in months_data:\n                    months_data[month_key] = {"cost": 0, "tokens": 0, "start": month_start}\n                \n                months_data[month_key]["cost"] += usage.cost\n                months_data[month_key]["tokens"] += usage.total_tokens\n            \n            trends = []\n            for month_key in sorted(months_data.keys()):\n                data = months_data[month_key]\n                month_start = data["start"]\n                \n                # Calculate month end\n                if month_start.month == 12:\n                    month_end = month_start.replace(year=month_start.year + 1, month=1, day=1) - timedelta(days=1)\n                else:\n                    month_end = month_start.replace(month=month_start.month + 1, day=1) - timedelta(days=1)\n                \n                month_end = month_end.replace(hour=23, minute=59, second=59, microsecond=999999)\n                \n                trends.append({\n                    "month_start": month_start,\n                    "month_end": month_end,\n                    "cost": data["cost"],\n                    "total_tokens": data["tokens"],\n                })\n            \n            return trends\n        \n        return []\n\n    def get_trends_by_project(self) -> List[Dict]:\n        """Get trends for all projects in the team.\n        \n        Returns:\n            List of dicts with trend data per project\n        """\n        projects = Project.objects.filter(team_id=self.team_id)\n        \n        trends_by_project = []\n        for project in projects:\n            usages = TokenUsage.objects.filter(project=project)\n            \n            if not usages:\n                continue\n            \n            # Calculate total cost for current week (last 7 days)\n            now = datetime.utcnow()\n            week_cost = 0\n            \n            # Last 7 days\n            week_start = now - timedelta(days=7)\n            \n            for usage in usages:\n                if week_start <= usage.timestamp <= now:\n                    week_cost += usage.cost\n            \n            trends_by_project.append({\n                "project_id": project.id,\n                "project_name": project.name,\n                "current_week_cost": week_cost,\n            })\n        \n        return trends_by_project\n'})
