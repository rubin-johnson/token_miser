wargs.items():\n            filtered = [obj for obj in filtered if getattr(obj, key, None) == value]\n        return FilterResult(filtered)\n    \n    def __iter__(self):\n        return iter(self.objects)\n    \n    def __len__(self):\n        return len(self.objects)\n\n\nclass MockDatabase:\n    """Mock database for testing."""\n    \n    def __init__(self):\n        self.project_manager = MockObjectManager()\n        self.project_manager._model_class = Project\n        self.token_usage_manager = MockObjectManager()\n        self.token_usage_manager._model_class = TokenUsage\n        self.anomaly_alert_manager = MockObjectManager()\n        self.anomaly_alert_manager._model_class = AnomalyAlert\n\n\n@pytest.fixture\ndef db():\n    """Provide a mock database for tests."""\n    mock_db = MockDatabase()\n    \n    # Inject the managers into the models\n    Project.objects = mock_db.project_manager\n    TokenUsage.objects = mock_db.token_usage_manager\n    AnomalyAlert.objects = mock_db.anomaly_alert_manager\n    \n    yield mock_db\n    \n    # Cleanup\n    mock_db.project_manager.objects = []\n    mock_db.token_usage_manager.objects = []\n    mock_db.anomaly_alert_manager.objects = []\n\n\n@pytest.fixture\ndef sample_project(db):\n    """Create a test project."""\n    return Project.objects.create(name="TestProject", team_id=1)\n\n\n@pytest.fixture\ndef baseline_usage_data(sample_project):\n    """Create 30 days of baseline usage (100 tokens/day)."""\n    now = datetime.utcnow()\n    from datetime import timedelta\n    for i in range(30):\n        timestamp = now - timedelta(days=30-i)\n        TokenUsage.objects.create(\n            project=sample_project,\n            tokens_input=50,\n            tokens_output=50,\n            cost=0.10,\n            model="gpt-4",\n            timestamp=timestamp\n        )\n'})
