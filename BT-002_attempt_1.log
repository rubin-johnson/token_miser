[Turn 25] Tool: write_file({'path': 'tests/test_anomaly_detection.py', 'content': '"""\nBehavioral tests for anomaly detection in token usage.\nThese tests verify that the system can detect spikes in token usage relative to a baseline\nand generate alerts with appropriate context.\n"""\nimport pytest\nfrom datetime import datetime, timedelta\nfrom token_miser.models import TokenUsage, Project, AnomalyAlert\nfrom token_miser.services.anomaly_detector import AnomalyDetector\n\n\ndef test_detect_spike_above_threshold(sample_project, baseline_usage_data):\n    """Test that spikes above threshold are detected."""\n    now = datetime.utcnow()\n    \n    # Current usage: 500 tokens (5x baseline of 100)\n    TokenUsage.objects.create(\n        project=sample_project,\n        tokens_input=250,\n        tokens_output=250,\n        cost=0.50,\n        model="gpt-4",\n        timestamp=now\n    )\n    \n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)  # 150% threshold\n    anomalies = detector.detect_anomalies()\n    \n    assert len(anomalies) == 1\n    assert anomalies[0]["project_id"] == sample_project.id\n    assert anomalies[0]["spike_magnitude"] == pytest.approx(5.0, rel=0.1)\n    assert anomalies[0]["timestamp"] == now\n\n\ndef test_no_alert_for_normal_variance(sample_project, baseline_usage_data):\n    """Test that normal usage variance does not trigger alerts."""\n    now = datetime.utcnow()\n    \n    # Current usage: 120 tokens (1.2x baseline of 100)\n    TokenUsage.objects.create(\n        project=sample_project,\n        tokens_input=60,\n        tokens_output=60,\n        cost=0.12,\n        model="gpt-4",\n        timestamp=now\n    )\n    \n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)  # 150% threshold\n    anomalies = detector.detect_anomalies()\n    \n    assert len(anomalies) == 0\n\n\ndef test_anomaly_includes_context(sample_project, baseline_usage_data):\n    """Test that anomalies include detailed context."""\n    now = datetime.utcnow()\n    \n    TokenUsage.objects.create(\n        project=sample_project,\n        tokens_input=300,\n        tokens_output=300,\n        cost=0.60,\n        model="gpt-4",\n        timestamp=now\n    )\n    \n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)\n    anomalies = detector.detect_anomalies()\n    \n    assert "project_name" in anomalies[0]\n    assert "baseline_tokens" in anomalies[0]\n    assert "current_tokens" in anomalies[0]\n    assert "spike_percentage" in anomalies[0]\n\n\ndef test_configurable_sensitivity_threshold(sample_project, baseline_usage_data):\n    """Test that sensitivity threshold can be adjusted."""\n    now = datetime.utcnow()\n    \n    # Current usage: 150 tokens (1.5x baseline)\n    TokenUsage.objects.create(\n        project=sample_project,\n        tokens_input=75,\n        tokens_output=75,\n        cost=0.15,\n        model="gpt-4",\n        timestamp=now\n    )\n    \n    # With high sensitivity (2.0), should NOT alert for 1.5x spike\n    detector_high = AnomalyDetector(team_id=1, sensitivity=2.0)\n    anomalies_high = detector_high.detect_anomalies()\n    assert len(anomalies_high) == 0\n    \n    # With low sensitivity (1.2), should alert for 1.5x spike\n    detector_low = AnomalyDetector(team_id=1, sensitivity=1.2)\n    anomalies_low = detector_low.detect_anomalies()\n    assert len(anomalies_low) == 1\n\n\ndef test_anomaly_detection_multiple_projects(db):\n    """Test anomaly detection across multiple projects."""\n    project1 = Project.objects.create(name="Project1", team_id=1)\n    project2 = Project.objects.create(name="Project2", team_id=1)\n    now = datetime.utcnow()\n    \n    # Baseline for project1 (100 tokens/day for 30 days)\n    for i in range(30):\n        timestamp = now - timedelta(days=30-i)\n        TokenUsage.objects.create(\n            project=project1,\n            tokens_input=50,\n            tokens_output=50,\n            cost=0.10,\n            model="gpt-4",\n            timestamp=timestamp\n        )\n    \n    # Baseline for project2 (200 tokens/day for 30 days)\n    for i in range(30):\n        timestamp = now - timedelta(days=30-i)\n        TokenUsage.objects.create(\n            project=project2,\n            tokens_input=100,\n            tokens_output=100,\n            cost=0.20,\n            model="gpt-4",\n            timestamp=timestamp\n        )\n    \n    # Spike in project1\n    TokenUsage.objects.create(\n        project=project1,\n        tokens_input=300,\n        tokens_output=300,\n        cost=0.60,\n        model="gpt-4",\n        timestamp=now\n    )\n    \n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)\n    anomalies = detector.detect_anomalies()\n    \n    assert len(anomalies) == 1\n    assert anomalies[0]["project_id"] == project1.id\n\n\ndef test_anomaly_detector_initialization():\n    """Test that anomaly detector initializes with team_id and sensitivity."""\n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)\n    assert detector.team_id == 1\n    assert detector.sensitivity == 1.5\n\n\ndef test_anomaly_baseline_calculation(sample_project):\n    """Test that baseline is calculated correctly from historical data."""\n    now = datetime.utcnow()\n    \n    # Create 7 days of usage: 100, 120, 110, 130, 100, 115, 105 tokens\n    usage_per_day = [100, 120, 110, 130, 100, 115, 105]\n    for i, tokens in enumerate(usage_per_day):\n        timestamp = now - timedelta(days=7-i)\n        TokenUsage.objects.create(\n            project=sample_project,\n            tokens_input=tokens//2,\n            tokens_output=tokens//2,\n            cost=0.1,\n            model="gpt-4",\n            timestamp=timestamp\n        )\n    \n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)\n    baseline = detector._calculate_baseline(sample_project.id)\n    \n    # Average should be approximately 114.3 tokens\n    assert baseline == pytest.approx(114.3, rel=0.05)\n\n\ndef test_anomaly_alert_persisted(sample_project, baseline_usage_data):\n    """Test that detected anomalies create AnomalyAlert records."""\n    now = datetime.utcnow()\n    \n    TokenUsage.objects.create(\n        project=sample_project,\n        tokens_input=300,\n        tokens_output=300,\n        cost=0.60,\n        model="gpt-4",\n        timestamp=now\n    )\n    \n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)\n    anomalies = detector.detect_anomalies()\n    \n    assert len(anomalies) == 1\n    # Verify that AnomalyAlert was persisted to database\n    assert AnomalyAlert.objects.filter(\n        project_id=sample_project.id,\n        team_id=1\n    ).exists()\n'})
