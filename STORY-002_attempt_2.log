[Turn 28] Tool: write_file({'path': 'token_miser/services/anomaly_detector.py', 'content': '"""Anomaly detection service for Token Miser."""\nfrom datetime import datetime, timedelta\nfrom typing import List, Dict, Optional\nfrom token_miser.models import TokenUsage, Project, AnomalyAlert\n\n\nclass AnomalyDetector:\n    """Detects anomalies in token usage patterns."""\n\n    def __init__(self, team_id: int, sensitivity: float = 1.5):\n        """Initialize the anomaly detector.\n        \n        Args:\n            team_id: The team ID to detect anomalies for\n            sensitivity: Sensitivity threshold for spike detection (default 1.5)\n                        Spike detected when current > baseline * sensitivity\n        """\n        self.team_id = team_id\n        self.sensitivity = sensitivity\n\n    def _calculate_baseline(self, project_id: int, lookback_days: int = 7) -> int:\n        """Calculate baseline token usage for a project.\n        \n        Calculates the average daily token usage over the last N days.\n        \n        Args:\n            project_id: The project ID to calculate baseline for\n            lookback_days: Number of days to look back (default 7)\n            \n        Returns:\n            Average daily tokens (sum of tokens_input + tokens_output per day, averaged)\n            Returns 0 if no historical data available\n        """\n        # Get the project\n        try:\n            projects = Project.objects.filter(id=project_id, team_id=self.team_id)\n            if not projects:\n                return 0\n            project = projects[0]\n        except (KeyError, IndexError):\n            return 0\n        \n        # Calculate the date range for lookback\n        now = datetime.utcnow()\n        start_date = now - timedelta(days=lookback_days)\n        \n        # Get all token usage records for this project within the lookback period\n        all_usages = TokenUsage.objects.filter(project=project)\n        \n        # Filter to lookback period\n        usages_in_period = []\n        for usage in all_usages:\n            if start_date <= usage.timestamp <= now:\n                usages_in_period.append(usage)\n        \n        if not usages_in_period:\n            return 0\n        \n        # Group by day and sum tokens\n        daily_totals = {}\n        for usage in usages_in_period:\n            # Get the date (without time) of this usage\n            date_key = usage.timestamp.date()\n            if date_key not in daily_totals:\n                daily_totals[date_key] = 0\n            daily_totals[date_key] += usage.tokens_input + usage.tokens_output\n        \n        if not daily_totals:\n            return 0\n        \n        # Calculate average daily tokens\n        average_daily_tokens = sum(daily_totals.values()) / len(daily_totals)\n        return int(average_daily_tokens)\n\n    def detect_anomalies(self) -> List[Dict]:\n        """Detect anomalies in token usage for the team.\n        \n        For each project in the team:\n        1. Calculate baseline tokens (average over last 7 days)\n        2. Get current day\'s total tokens\n        3. If current > baseline * sensitivity, create AnomalyAlert and add to results\n        \n        Returns:\n            List of dicts with detected anomalies, each containing:\n            - project_id: The project ID\n            - project_name: The project name\n            - baseline_tokens: The calculated baseline\n            - current_tokens: The current day\'s total\n            - spike_magnitude: current_tokens / baseline_tokens\n            - spike_percentage: ((current_tokens - baseline_tokens) / baseline_tokens) * 100\n            - timestamp: The detection timestamp\n        """\n        anomalies = []\n        \n        # Get all projects for this team\n        projects = Project.objects.filter(team_id=self.team_id)\n        \n        # Get today\'s date range\n        now = datetime.utcnow()\n        today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)\n        today_end = today_start + timedelta(days=1)\n        \n        for project in projects:\n            # Calculate baseline for this project\n            baseline_tokens = self._calculate_baseline(project.id)\n            \n            # Skip if no baseline data available or baseline is 0\n            if baseline_tokens <= 0:\n                continue\n            \n            # Get current day\'s total tokens\n            all_usages = TokenUsage.objects.filter(project=project)\n            current_tokens = 0\n            for usage in all_usages:\n                if today_start <= usage.timestamp < today_end:\n                    current_tokens += usage.tokens_input + usage.tokens_output\n            \n            # Check for spike\n            if current_tokens > baseline_tokens * self.sensitivity:\n                # Calculate spike metrics\n                spike_magnitude = current_tokens / baseline_tokens if baseline_tokens > 0 else 0.0\n                spike_percentage = ((current_tokens - baseline_tokens) / baseline_tokens * 100) if baseline_tokens > 0 else 0.0\n                \n                # Create AnomalyAlert record\n                alert = AnomalyAlert.objects.create(\n                    team_id=self.team_id,\n                    project_id=project.id,\n                    project_name=project.name,\n                    baseline_tokens=baseline_tokens,\n                    current_tokens=current_tokens,\n                    spike_magnitude=spike_magnitude,\n                    spike_percentage=spike_percentage,\n                    status="active",\n                    timestamp=now\n                )\n                \n                # Add to results list\n                anomalies.append({\n                    "project_id": project.id,\n                    "project_name": project.name,\n                    "baseline_tokens": baseline_tokens,\n                    "current_tokens": current_tokens,\n                    "spike_magnitude": spike_magnitude,\n                    "spike_percentage": spike_percentage,\n                    "timestamp": now\n                })\n        \n        return anomalies\n'})
