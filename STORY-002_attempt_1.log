[Turn 38] Tool: write_file({'path': 'token_miser/services/anomaly_detector.py', 'content': '"""Anomaly detection service for Token Miser."""\nfrom datetime import datetime, timedelta\nfrom typing import List, Optional, Dict, Any\nfrom token_miser.models import TokenUsage, Project, AnomalyAlert\n\n\nclass AnomalyDetector:\n    """Detects anomalies in token usage patterns."""\n    \n    def __init__(self, team_id: int, sensitivity: float = 1.5):\n        """Initialize the anomaly detector.\n        \n        Args:\n            team_id: The team ID to analyze\n            sensitivity: Sensitivity threshold (default 1.5, meaning 150% of baseline)\n        """\n        self.team_id = team_id\n        self.sensitivity = sensitivity\n    \n    def _calculate_baseline(self, project_id: int) -> int:\n        """Calculate baseline tokens for a project over the last 7 days (excluding today).\n        \n        Args:\n            project_id: The project ID to calculate baseline for\n            \n        Returns:\n            Average daily tokens over the last 7 days, or 0 if no data\n        """\n        now = datetime.utcnow()\n        # Start from 8 days ago (to get 7 full days before today)\n        eight_days_ago = now - timedelta(days=8)\n        # End at start of today\n        today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)\n        \n        # Get all projects to find the one matching project_id\n        projects = Project.objects.filter(team_id=self.team_id)\n        target_project = None\n        for p in projects:\n            if p.id == project_id:\n                target_project = p\n                break\n        \n        if target_project is None:\n            return 0\n        \n        # Get all token usages for this project in the last 7-8 days\n        usages = TokenUsage.objects.filter(project=target_project)\n        \n        # Filter by date range (exclude today)\n        usages_in_range = []\n        for usage in usages:\n            if eight_days_ago <= usage.timestamp < today_start:\n                usages_in_range.append(usage)\n        \n        if not usages_in_range:\n            return 0\n        \n        # Group by day and sum tokens per day\n        daily_totals = {}\n        for usage in usages_in_range:\n            day = usage.timestamp.replace(hour=0, minute=0, second=0, microsecond=0)\n            day_key = day.date()\n            if day_key not in daily_totals:\n                daily_totals[day_key] = 0\n            daily_totals[day_key] += usage.tokens_input + usage.tokens_output\n        \n        if not daily_totals:\n            return 0\n        \n        # Calculate average\n        total_tokens = sum(daily_totals.values())\n        num_days = len(daily_totals)\n        baseline = total_tokens / num_days\n        \n        return int(baseline)\n    \n    def detect_anomalies(self) -> List[Dict[str, Any]]:\n        """Detect anomalies in token usage for all projects in this team.\n        \n        Returns:\n            List of detected anomalies with:\n            - project_id: The project ID\n            - project_name: The project name\n            - baseline_tokens: Baseline daily tokens\n            - current_tokens: Current day\'s tokens\n            - spike_magnitude: Current / baseline ratio\n            - spike_percentage: Percentage increase from baseline\n            - timestamp: When the anomaly was detected\n        """\n        anomalies = []\n        \n        # Get all projects for this team\n        projects = Project.objects.filter(team_id=self.team_id)\n        \n        # Get today\'s date range\n        now = datetime.utcnow()\n        today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)\n        today_end = (today_start + timedelta(days=1)) - timedelta(seconds=1)\n        \n        for project in projects:\n            # Calculate baseline for this project\n            baseline = self._calculate_baseline(project.id)\n            \n            # Skip if no baseline data or baseline is zero\n            if baseline <= 0:\n                continue\n            \n            # Get today\'s token usage for this project\n            usages = TokenUsage.objects.filter(project=project)\n            today_usages = []\n            for usage in usages:\n                if today_start <= usage.timestamp <= today_end:\n                    today_usages.append(usage)\n            \n            # Calculate current day\'s total\n            current_tokens = sum(usage.tokens_input + usage.tokens_output for usage in today_usages)\n            \n            # Check if current usage exceeds baseline * sensitivity threshold\n            threshold = baseline * self.sensitivity\n            if current_tokens > threshold:\n                # Calculate spike metrics\n                spike_magnitude = current_tokens / baseline\n                spike_percentage = ((current_tokens - baseline) / baseline) * 100\n                \n                # Create anomaly alert record\n                alert = AnomalyAlert(\n                    team_id=self.team_id,\n                    project_id=project.id,\n                    project_name=project.name,\n                    baseline_tokens=baseline,\n                    current_tokens=current_tokens,\n                    spike_magnitude=spike_magnitude,\n                    spike_percentage=spike_percentage,\n                    status="active",\n                    timestamp=now,\n                )\n                alert.save()\n                \n                # Add to results\n                anomalies.append({\n                    "project_id": project.id,\n                    "project_name": project.name,\n                    "baseline_tokens": baseline,\n                    "current_tokens": current_tokens,\n                    "spike_magnitude": spike_magnitude,\n                    "spike_percentage": spike_percentage,\n                    "timestamp": now,\n                })\n        \n        return anomalies\n'})
