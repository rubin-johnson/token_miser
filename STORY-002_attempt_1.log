n        team_id=1,\n        project_id=1,\n        project_name="TestProject",\n        baseline_tokens=100,\n        current_tokens=500,\n        spike_magnitude=5.0,\n        spike_percentage=400,\n        status="active"\n    )\n    \n    assert alert.team_id == 1\n    assert alert.project_id == 1\n    assert alert.project_name == "TestProject"\n    assert alert.baseline_tokens == 100\n    assert alert.current_tokens == 500\n    assert alert.spike_magnitude == 5.0\n    assert alert.spike_percentage == 400\n    assert alert.status == "active"\n    assert hasattr(alert, \'timestamp\')\n    assert hasattr(alert, \'created_at\')\n\n\ndef test_anomaly_detector_with_single_project():\n    """Test anomaly detection with a single project."""\n    # Create project\n    project = Project(name="TestProject", team_id=1)\n    \n    # Create detector\n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)\n    \n    # Since Project.objects is now using our custom manager, we can use it\n    # Add baseline usage (7 days worth of 100 tokens/day)\n    now = datetime.utcnow()\n    for i in range(7):\n        date = now - timedelta(days=i+1)\n        usage = TokenUsage(\n            project=project,\n            tokens_input=50,\n            tokens_output=50,\n            cost=0.01,\n            model="gpt-4",\n            timestamp=date\n        )\n    \n    # Run detection\n    anomalies = detector.detect_anomalies()\n    \n    # Should be empty because no anomalies yet\n    assert isinstance(anomalies, list)\n\n\ndef test_anomaly_detection_threshold():\n    """Test that anomalies are detected when threshold is exceeded."""\n    # Create project\n    project = Project(name="TestProject", team_id=1)\n    \n    # Create detector with sensitivity 1.5 (150%)\n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)\n    \n    # Add baseline usage (7 days worth of 100 tokens/day)\n    now = datetime.utcnow()\n    for i in range(7):\n        date = now - timedelta(days=i+1)\n        usage = TokenUsage(\n            project=project,\n            tokens_input=50,\n            tokens_output=50,  # Total 100 tokens/day\n            cost=0.01,\n            model="gpt-4",\n            timestamp=date\n        )\n    \n    # Add today\'s usage that exceeds threshold (150 > 100 * 1.5)\n    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)\n    today_usage = TokenUsage(\n        project=project,\n        tokens_input=80,\n        tokens_output=80,  # Total 160 tokens (exceeds 150 threshold)\n        cost=0.02,\n        model="gpt-4",\n        timestamp=today_start + timedelta(hours=1)\n    )\n    \n    # Run detection\n    anomalies = detector.detect_anomalies()\n    \n    # Should detect one anomaly\n    assert len(anomalies) == 1\n    assert anomalies[0][\'project_id\'] == project.id\n    assert anomalies[0][\'project_name\'] == "TestProject"\n    assert anomalies[0][\'baseline_tokens\'] == 100\n    assert anomalies[0][\'current_tokens\'] == 160\n\n\ndef test_anomaly_alert_persists():\n    """Test that detected anomalies create persistent AnomalyAlert records."""\n    # Create project\n    project = Project(name="TestProject", team_id=1)\n    \n    # Create detector\n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)\n    \n    # Add baseline usage\n    now = datetime.utcnow()\n    for i in range(7):\n        date = now - timedelta(days=i+1)\n        usage = TokenUsage(\n            project=project,\n            tokens_input=50,\n            tokens_output=50,\n            cost=0.01,\n            model="gpt-4",\n            timestamp=date\n        )\n    \n    # Add today\'s usage that exceeds threshold\n    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)\n    today_usage = TokenUsage(\n        project=project,\n        tokens_input=80,\n        tokens_output=80,\n        cost=0.02,\n        model="gpt-4",\n        timestamp=today_start + timedelta(hours=1)\n    )\n    \n    # Get baseline alert count\n    initial_alerts = len(AnomalyAlert.objects.all())\n    \n    # Run detection\n    anomalies = detector.detect_anomalies()\n    \n    # Should have created one more alert\n    final_alerts = len(AnomalyAlert.objects.all())\n    assert final_alerts > initial_alerts\n\n\ndef test_spike_magnitude_calculation():\n    """Test that spike magnitude is calculated correctly."""\n    alert = AnomalyAlert(\n        team_id=1,\n        project_id=1,\n        project_name="TestProject",\n        baseline_tokens=100,\n        current_tokens=250,\n        spike_magnitude=2.5,\n        spike_percentage=150,\n        status="active"\n    )\n    \n    assert alert.spike_magnitude == 2.5\n    assert alert.spike_percentage == 150\n\n\ndef test_multiple_projects_detection():\n    """Test anomaly detection with multiple projects."""\n    # Create projects\n    project1 = Project(name="Project1", team_id=1)\n    project2 = Project(name="Project2", team_id=1)\n    \n    # Create detector\n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)\n    \n    # Add baseline usage for both\n    now = datetime.utcnow()\n    for i in range(7):\n        date = now - timedelta(days=i+1)\n        # Project 1: 100 tokens/day\n        usage1 = TokenUsage(\n            project=project1,\n            tokens_input=50,\n            tokens_output=50,\n            cost=0.01,\n            model="gpt-4",\n            timestamp=date\n        )\n        # Project 2: 200 tokens/day\n        usage2 = TokenUsage(\n            project=project2,\n            tokens_input=100,\n            tokens_output=100,\n            cost=0.02,\n            model="gpt-4",\n            timestamp=date\n        )\n    \n    # Add today\'s usage\n    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)\n    # Project 1: 160 tokens (exceeds 150 threshold)\n    today_usage1 = TokenUsage(\n        project=project1,\n        tokens_input=80,\n        tokens_output=80,\n        cost=0.02,\n        model="gpt-4",\n        timestamp=today_start + timedelta(hours=1)\n    )\n    # Project 2: 320 tokens (exceeds 300 threshold)\n    today_usage2 = TokenUsage(\n        project=project2,\n        tokens_input=160,\n        tokens_output=160,\n        cost=0.04,\n        model="gpt-4",\n        timestamp=today_start + timedelta(hours=1)\n    )\n    \n    # Run detection\n    anomalies = detector.detect_anomalies()\n    \n    # Should detect anomalies in both projects\n    assert len(anomalies) == 2\n\n\ndef test_no_anomaly_below_threshold():\n    """Test that no anomaly is detected when below threshold."""\n    # Create project\n    project = Project(name="TestProject", team_id=1)\n    \n    # Create detector with sensitivity 1.5\n    detector = AnomalyDetector(team_id=1, sensitivity=1.5)\n    \n    # Add baseline usage (100 tokens/day)\n    now = datetime.utcnow()\n    for i in range(7):\n        date = now - timedelta(days=i+1)\n        usage = TokenUsage(\n            project=project,\n            tokens_input=50,\n            tokens_output=50,\n            cost=0.01,\n            model="gpt-4",\n            timestamp=date\n        )\n    \n    # Add today\'s usage that does NOT exceed threshold (140 < 150)\n    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)\n    today_usage = TokenUsage(\n        project=project,\n        tokens_input=70,\n        tokens_output=70,  # Total 140 tokens (below 150 threshold)\n        cost=0.02,\n        model="gpt-4",\n        timestamp=today_start + timedelta(hours=1)\n    )\n    \n    # Run detection\n    anomalies = detector.detect_anomalies()\n    \n    # Should detect no anomalies\n    assert anomalies == []\n'})
