// Dispatch routes commands to their handlers
func Dispatch(command string, args []string, w ...io.Writer) error {
	var out io.Writer = os.Stdout
	if len(w) > 0 && w[0] != nil {
		out = w[0]
	}
	switch command {
	case "run":
		return runCommand(args, out)
