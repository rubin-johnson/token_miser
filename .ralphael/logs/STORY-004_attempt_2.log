import re
import subprocess


def run_cli(args):
    proc = subprocess.run(
        ["token-miser"] + args,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        check=False,
    )
    return proc.returncode, proc.stdout


