\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/spf13/cobra\"\n\t\"gopkg.in/yaml.v2\"\n\n\t\"github.com/example/token-miser/internal/claude\"\n\t\"github.com/example/token-miser/internal/compare\"\n\t\"github.com/example/token-miser/internal/env\"\n\t\"github.com/example/token-miser/internal/eval\"\n\t\"github.com/example/token-miser/internal/quality\"\n\t\"github.com/example/token-miser/internal/storage\"\n\t\"github.com/example/token-miser/internal/task\"\n)\n\n// NewRootCmd creates the root command for token-miser\nfunc NewRootCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"token-miser\",\n\t\tShort: \"A tool for measuring token efficiency in AI experiments\",\n\t\tLong:  \"Token Miser helps you run controlled experiments to measure token efficiency across different AI model configurations.\",\n\t}\n\n\t// Add subcommands\n\tcmd.AddCommand(newRunCmd())\n\tcmd.AddCommand(newCompareCmd())\n\tcmd.AddCommand(newHistoryCmd())\n\tcmd.AddCommand(newTasksCmd())\n\n\treturn cmd\n}\n\nfunc newRunCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"run\",\n\t\tShort: \"Run an experiment\",\n\t\tRunE:  runExperiment,\n\t}\n\n\tcmd.Flags().String(\"task\", \"\", \"Path to task YAML file\")\n\tcmd.Flags().String(\"control\", \"vanilla\", \"Control treatment name\")\n\tcmd.Flags().String(\"treatment\", \"\", \"Path to treatment YAML file\")\n\tcmd.Flags().String(\"model\", \"sonnet\", \"Model to use\")\n\tcmd.MarkFlagRequired(\"task\")\n\tcmd.MarkFlagRequired(\"treatment\")\n\n\treturn cmd\n}\n\nfunc newCompareCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"compare\",\n\t\tShort: \"Compare experiment results\",\n\t\tRunE:  compareResults,\n\t}\n\n\tcmd.Flags().String(\"task\", \"\", \"Task ID to compare\")\n\tcmd.MarkFlagRequired(\"task\")\n\n\treturn cmd\n}\n\nfunc newHistoryCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"history\",\n\t\tShort: \"Show experiment history\",\n\t\tRunE:  showHistory