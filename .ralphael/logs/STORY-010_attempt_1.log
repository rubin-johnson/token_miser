n\t\tfmt.Printf("\\n✗ Treatment is %.2f%% less efficient\\n", \n\t\t\t(controlResult.Efficiency-treatmentResult.Efficiency)/controlResult.Efficiency*100)\n\t}\n\n\treturn nil\n}\n\ntype ArmResult struct {\n\tTokens     int\n\tQuality    float64\n\tEfficiency float64\n\tRunID      string\n}\n\nfunc runArm(taskData *task.Task, treatmentName, model, armType string) (*ArmResult, error) {\n\t// Setup environment\n\tenvConfig, err := env.SetupEnv(taskData)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf("failed to setup environment: %w", err)\n\t}\n\tdefer env.TeardownEnv(envConfig)\n\n\t// Run Claude\n\tresponse, err := claude.RunClaude(taskData, model)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf("failed to run Claude: %w", err)\n\t}\n\n\t// Evaluate criteria\n\tcriteriaResult, err := eval.EvaluateCriteria(taskData, response)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf("failed to evaluate criteria: %w", err)\n\t}\n\n\t// Score quality\n\tqualityScore, err := quality.ScoreQuality(taskData, response, criteriaResult)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf("failed to score quality: %w", err)\n\t}\n\n\t// Store run\n\trunData := &storage.Run{\n\t\tID:          fmt.Sprintf("%s-%s-%d", taskData.ID, armType, time.Now().Unix()),\n\t\tTaskID:      taskData.ID,\n\t\tTreatment:   treatmentName,\n\t\tModel:       model,\n\t\tTokens:      response.Tokens,\n\t\tQuality:     qualityScore.Score,\n\t\tEfficiency:  qualityScore.Score / float64(response.Tokens) * 1000, // per 1k tokens\n\t\tTimestamp:   time.Now(),\n\t\tResponse:    response.Content,\n\t\tCriteria:    criteriaResult,\n\t}\n\n\tif err := storage.StoreRun(runData); err != nil {\n\t\treturn nil, fmt.Errorf("failed to store run: %w", err)\n\t}\n\n\treturn &ArmResult{\n\t\tTokens:     response.Tokens,\n\t\tQuality:    qualityScore.Score,\n\t\tEfficiency: runData.Efficiency,\n\t\tRunID:      runData.ID,\n\t}, nil\n}\n\nfunc compareResults(cmd *cobra.Command, args []string) error {\n\ttaskID, _ := cmd.Flags().GetString("task")\n\n\tcomparison, err := compare.Compare(taskID)\n\tif err != nil {\n\t\treturn fmt.Errorf("failed to compare results: %w", err)\n\t}\n\n\tfmt.Printf("=== COMPARISON FOR TASK %s ===\\n", taskID)\n\tfmt.Printf("Control runs: %d\\n", len(comparison.ControlRuns))\n\tfmt.Printf("Treatment runs: %d\\n", len(comparison.TreatmentRuns))\n\tfmt.Printf("\\nAverage Control Efficiency: %.2f\\n", comparison.ControlAvg)\n\tfmt.Printf("Average Treatment Efficiency: %.2f\\n", comparison.TreatmentAvg)\n\tfmt.Printf("Improvement: %.2f%% (%s)\\n", \n\t\tcomparison.ImprovementPct, \n\t\tmap[bool]string{true: "significant", false: "not significant"}[comparison.Significant])\n\n\treturn nil\n}\n\nfunc showHistory(cmd *cobra.Command, args []string) error {\n\truns, err := storage.ListRuns()\n\tif err != nil {\n\t\treturn fmt.Errorf("failed to list runs: %w", err)\n\t}\n\n\tfmt.Printf("=== EXPERIMENT HISTORY ===\\n")\n\tfmt.Printf("%-20s %-15s %-10s %-8s %-8s %-10s %s\\n", \n\t\t"RUN ID", "TASK", "TREATMENT", "TOKENS", "QUALITY", "EFFICIENCY", "TIMESTAMP")\n\tfmt.Printf("%s\\n", strings.Repeat("-", 90))\n\n\tfor _, run := range runs {\n\t\tfmt.Printf("%-20s %-15s %-10s %-8d %-8.2f %-10.2f %s\\n",\n\t\t\trun.ID, run.TaskID, run.Treatment, run.Tokens, run.Quality, run.Efficiency,\n\t\t\trun.Timestamp.Format("2006-01-02 15:04"))\n\t}\n\n\tfmt.Printf("\\nTotal runs: %d\\n", len(runs))\n\treturn nil\n}\n\nfunc listTasks(cmd *cobra.Command, args []string) error {\n\tdir, _ := cmd.Flags().GetString("dir")\n\n\tfiles, err := filepath.Glob(filepath.Join(dir, "*.yaml"))\n\tif err != nil {\n\t\treturn fmt.Errorf("failed to list task files: %w", err)\n\t}\n\n\tfmt.Printf("=== AVAILABLE TASKS ===\\n")\n\tfmt.Printf("%-15s %s\\n", "TASK ID", "NAME")\n\tfmt.Printf("%s\\n", strings.Repeat("-", 50))\n\n\tfor _, file := range files {\n\t\ttaskData, err := task.LoadTask(file)\n\t\tif err != nil {\n\t\t\tfmt.Printf("%-15s ERROR: %v\\n", filepath.Base(file), err)\n\t\t\tcontinue\n\t\t}\n\t\tfmt.Printf